#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
LAUNCHER_HOME="${CMUX_CODEX_LAUNCHER_HOME:-$HOME/.config/cmux-codex-launcher}"
STATE_DIR="$LAUNCHER_HOME/state"
LAST_STATE="$STATE_DIR/last.env"

PROFILE="${CMUX_CODEX_LAUNCHER_PROFILE:-penny}"
PROJECT_OVERRIDE=""
NAME_OVERRIDE=""
WORKSPACE_OVERRIDE=""
PREVIEW_OVERRIDE=""
DEV_COMMAND_OVERRIDE=""
PICKER_QUERY=""
GITHUB_OVERRIDE=""
DRY_RUN=0
PRINT_LAYOUT=0
OPEN_CODEX_APP_OVERRIDE=""
AUTOSTART_ROLES_OVERRIDE=""
CREATE_CMUX=1
CODEX_APP_FIRST=0
PROFILE_EXPLICIT=0
SEED_CODEX_FILES=0
RESET_TASK_CONTEXT=0
RESUME_LAST=0
STATUS_LAST=0
FOCUS_WORKSPACE="true"
INTERACTIVE_PICKER=0
CLONE_MISSING_GITHUB=1

declare -a CML_EXTRA_DOCS=()
declare -a CML_ROLE_NAMES=()

usage() {
  cat <<'EOF'
Usage:
  cmux-codex-launcher [--profile name] [--project /path/to/repo] [options]

Options:
  --profile <name>        Load profiles/<name>.env (default: penny)
  --project <path>        Override the project path
  --name <name>           Override the project name
  --workspace-name <name> Override the cmux workspace name
  --preview-url <url>     Override the browser preview URL
  --dev-command <command> Override the dev-server terminal command
  --choose                Ask for a project/file/app/repo and GitHub target, then launch
  --query <text>          Seed --choose search; selects the best match without a TTY
  --github <repo|url>     Override the GitHub repo for --choose
  --no-clone              Do not clone a GitHub-only match
  --codex                 Codex-app-first chooser: seed workflow files, open Codex app, skip cmux
  --seed-codex-files      Create missing Codex workflow files in the target repo
  --no-seed-codex-files   Do not create target-repo Codex workflow files
  --reset-task            Reset this launcher's shared context to a blank current task
  --app                   Open Codex desktop app (default unless profile disables it)
  --no-app                Do not open Codex desktop app
  --autostart-roles       Send each role prompt immediately to Codex CLI
  --no-autostart-roles    Open role tabs idle (default for Penny)
  --no-cmux               Do not create a cmux workspace
  --dry-run               Print launch plan and layout without opening anything
  --print-layout          Print only the cmux layout JSON
  --resume-last           Use the last launched profile/project path
  --status-last           Print the last launched profile/project path
  --no-focus              Create cmux workspace without focusing it
  -h, --help              Show help

Examples:
  bin/cmux-codex-launcher --profile penny
  bin/cmux-codex-launcher --project /Users/me/Projects/app --name App
  bin/cmux-codex-launcher --choose
  bin/cmux-codex-launcher --codex --query app
  bin/cmux-codex-launcher --profile penny --dry-run
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

shell_quote() {
  local value=${1:-}
  value=${value//\'/\'\\\'\'}
  printf "'%s'" "$value"
}

json_string() {
  local value=${1:-}
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/}
  value=${value//$'\t'/\\t}
  printf '"%s"' "$value"
}

slugify() {
  local value=${1:-project}
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-')"
  value="${value#-}"
  value="${value%-}"
  [ -n "$value" ] || value="project"
  printf '%s' "$value"
}

strip_tabs() {
  printf '%s' "${1:-}" | tr '\t\r\n' '   ' | sed 's/  */ /g; s/^ //; s/ $//'
}

join_comma() {
  local IFS=,
  printf '%s' "$*"
}

profile_path_for() {
  local name=$1
  local user_path="$LAUNCHER_HOME/profiles/$name.env"
  local repo_path="$REPO_DIR/profiles/$name.env"

  if [ -f "$user_path" ]; then
    printf '%s' "$user_path"
    return 0
  fi
  if [ -f "$repo_path" ]; then
    printf '%s' "$repo_path"
    return 0
  fi
  return 1
}

role_key() {
  printf '%s' "$1" | tr '[:lower:]- ' '[:upper:]__' | tr -cs 'A-Z0-9_' '_'
}

normalize_github_repo_ref() {
  local value=${1:-}
  local ref

  case "$value" in
    git@github.com:*)
      ref="${value#git@github.com:}"
      ;;
    ssh://git@github.com/*)
      ref="${value#ssh://git@github.com/}"
      ;;
    https://github.com/*)
      ref="${value#https://github.com/}"
      ;;
    http://github.com/*)
      ref="${value#http://github.com/}"
      ;;
    github.com/*)
      ref="${value#github.com/}"
      ;;
    */*)
      ref="$value"
      ;;
    *)
      return 1
      ;;
  esac

  ref="${ref%.git}"
  ref="${ref%%#*}"
  ref="${ref%%\?*}"
  ref="${ref%/}"
  [ -n "$ref" ] || return 1
  printf '%s' "$ref"
}

github_ssh_url() {
  local ref=$1
  printf 'git@github.com:%s.git' "$ref"
}

git_origin_ref_for() {
  local project_dir=$1
  local remote ref

  remote="$(git -C "$project_dir" remote get-url origin 2>/dev/null || true)"
  [ -n "$remote" ] || return 1
  ref="$(normalize_github_repo_ref "$remote" 2>/dev/null || true)"
  [ -n "$ref" ] || return 1
  printf '%s' "$ref"
}

role_prompt_for() {
  local role=$1
  local key var_name value
  key="$(role_key "$role")"
  var_name="CML_ROLE_PROMPT_$key"
  value="${!var_name:-}"
  if [ -n "$value" ]; then
    printf '%s' "$value"
    return
  fi

  printf 'Read the target project instructions and docs first. You own the %s workstream. Keep scope narrow, report changed files and verification, and update the shared context file before handoff.' "$role"
}

existing_doc_list() {
  local project_dir=$1
  local doc
  local -a docs=()

  for doc in AGENTS.md README.md docs/knowledge.md docs/queue.md "$CML_PLAN_DOC"; do
    [ -n "${doc:-}" ] || continue
    [ -f "$project_dir/$doc" ] && docs+=("$doc")
  done

  if [ "${#CML_EXTRA_DOCS[@]}" -gt 0 ]; then
    for doc in "${CML_EXTRA_DOCS[@]}"; do
      [ -n "${doc:-}" ] || continue
      [ -f "$project_dir/$doc" ] && docs+=("$doc")
    done
  fi

  printf '%s\n' "${docs[@]}" | awk 'NF && !seen[$0]++'
}

create_shared_context() {
  local project_name=$1
  local project_dir=$2
  local slug session_file
  slug="$(slugify "$project_name")"
  mkdir -p "$HOME/.codex/cmux-codex-launcher"
  session_file="$HOME/.codex/cmux-codex-launcher/$slug-shared-context.md"

  if [ ! -f "$session_file" ]; then
    cat > "$session_file" <<EOF
# cmux Codex shared context

- Project name: $project_name
- Project directory: $project_dir
- Launcher: cmux-codex-launcher
- State: initialized

## Current Task

- Goal: wait for the user to give the next task.
- Scope: undefined until the user gives a task.
- Status: ready.

## Handoff Notes

- Use this file for current task state and handoff notes.
- Keep durable project knowledge in the target project's docs.
- Do not duplicate secrets here.
EOF
  fi

  printf '%s' "$session_file"
}

update_shared_context_selection() {
  local session_file=$1
  local project_name=$2
  local project_dir=$3
  local tmp

  tmp="$(mktemp -t cmux-codex-context.XXXXXX)"
  if [ -f "$session_file" ] && grep -q '<!-- launcher-selection:start -->' "$session_file"; then
    awk \
      -v project_name="$project_name" \
      -v project_dir="$project_dir" \
      -v selected_target="${CML_SELECTED_TARGET:-unspecified}" \
      -v github_repo="${CML_GITHUB_REPO:-use target repo origin}" \
      -v updated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      '
      /<!-- launcher-selection:start -->/ {
        print "<!-- launcher-selection:start -->"
        print "## Launcher Selection"
        print ""
        print "- Project name: " project_name
        print "- Project directory: " project_dir
        print "- Selected target: " selected_target
        print "- GitHub contribution target: " github_repo
        print "- Updated at: " updated_at
        print "<!-- launcher-selection:end -->"
        skip=1
        next
      }
      /<!-- launcher-selection:end -->/ {
        skip=0
        next
      }
      !skip { print }
    ' "$session_file" > "$tmp"
    mv "$tmp" "$session_file"
  else
    cat "$session_file" > "$tmp"
    cat >> "$tmp" <<EOF

<!-- launcher-selection:start -->
## Launcher Selection

- Project name: $project_name
- Project directory: $project_dir
- Selected target: ${CML_SELECTED_TARGET:-unspecified}
- GitHub contribution target: ${CML_GITHUB_REPO:-use target repo origin}
- Updated at: $(date -u +%Y-%m-%dT%H:%M:%SZ)
<!-- launcher-selection:end -->
EOF
    mv "$tmp" "$session_file"
  fi
}

reset_shared_context_task() {
  local session_file=$1
  local tmp

  tmp="$(mktemp -t cmux-codex-task.XXXXXX)"
  if [ -f "$session_file" ] && grep -q '<!-- codex-task:start -->' "$session_file"; then
    awk \
      -v updated_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
      '
      /<!-- codex-task:start -->/ {
        print "<!-- codex-task:start -->"
        print "## Codex Task"
        print ""
        print "- Goal: wait for the user to give the next concrete task."
        print "- Scope: no repo-visible changes until the task is stated."
        print "- Status: ready."
        print "- Updated at: " updated_at
        print ""
        print "## Working Notes"
        print ""
        print "- Assumptions: none yet."
        print "- Success criteria: define before editing."
        print "- Verification: choose the narrowest useful proof once the task is known."
        print "<!-- codex-task:end -->"
        skip=1
        next
      }
      /<!-- codex-task:end -->/ {
        skip=0
        next
      }
      !skip { print }
    ' "$session_file" > "$tmp"
    mv "$tmp" "$session_file"
  else
    cat "$session_file" > "$tmp"
    cat >> "$tmp" <<EOF

<!-- codex-task:start -->
## Codex Task

- Goal: wait for the user to give the next concrete task.
- Scope: no repo-visible changes until the task is stated.
- Status: ready.
- Updated at: $(date -u +%Y-%m-%dT%H:%M:%SZ)

## Working Notes

- Assumptions: none yet.
- Success criteria: define before editing.
- Verification: choose the narrowest useful proof once the task is known.
<!-- codex-task:end -->
EOF
    mv "$tmp" "$session_file"
  fi
}

seed_codex_project_files() {
  local project_name=$1
  local project_dir=$2

  mkdir -p "$project_dir/docs" "$project_dir/.codex"

  if [ ! -e "$project_dir/AGENTS.md" ]; then
    cat > "$project_dir/AGENTS.md" <<EOF
# AGENTS.md

## Purpose

This repo is worked by Codex sessions launched through cmux-codex-launcher.

## Read First

- README.md when present.
- docs/agent-workflow.md
- docs/queue.md
- docs/knowledge.md

## Rules

- Follow the user's latest request.
- Keep current-task state in the shared context file printed by the launcher.
- Keep durable project facts in docs/knowledge.md.
- Keep the next small task in docs/queue.md.
- State assumptions before implementation when they affect the path.
- Verify with the narrowest useful local command before committing or pushing.
- Do not store secrets in repo docs, profiles, .codex config, commits, or PR bodies.
EOF
  fi

  if [ ! -e "$project_dir/docs/agent-workflow.md" ]; then
    cat > "$project_dir/docs/agent-workflow.md" <<EOF
# Agent Workflow

This is the Codex-first workflow source for "$project_name".

## Codex App Loop

1. Read AGENTS.md, then this file.
2. Read the shared context file printed by the launcher.
3. Check docs/queue.md for the next task and docs/knowledge.md for durable facts.
4. Define success criteria before editing.
5. Make the smallest coherent change.
6. Run the proof that matches the risk.
7. Update the shared context with status, changed files, verification, and next action.

## Context Reset

- Treat about 80% context used as the reset point.
- Before compacting or starting a fresh Codex app thread, update the shared context file.
- Keep current task state in the shared context file, not in AGENTS.md.
- Keep durable reusable knowledge in docs/knowledge.md.

## Parallel Work

- Split only when tasks have clear file ownership.
- Prefer one Codex app thread per file, feature slice, or proof.
- Do not let two sessions edit the same file unless one lead session sequences the work.
- Finished sessions should report changed files, verification, residual risk, and ship status.

## Ship Path

- Follow the repo-local AGENTS.md and the selected GitHub target from the launcher.
- Commit and push only verified repo-visible work.
- Keep private, scratch, partial, failing, and unverified work out of the publish path.
EOF
  fi

  if [ ! -e "$project_dir/docs/queue.md" ]; then
    cat > "$project_dir/docs/queue.md" <<'EOF'
# Queue

## Now

- [ ] Capture the next concrete Codex task.

## Next

- [ ] Add the next smallest shippable step.
- [ ] Capture the main edge case.
- [ ] Capture one cleanup item.

## Blocked

- [ ] No blockers recorded yet.

## Discovered While Working

- [ ] Add useful follow-ups here instead of expanding the active task.
EOF
  fi

  if [ ! -e "$project_dir/docs/knowledge.md" ]; then
    cat > "$project_dir/docs/knowledge.md" <<'EOF'
# Knowledge

## User-Provided Knowledge

- Capture durable user guidance, preferences, and constraints that should survive a single task.

## Project Facts

- Capture stable project facts, decisions, and summaries worth reusing.

## Retrieval Hints

- Search this file, the shared context file, and nearby repo docs with `rg` before broader search.
- Label each note by source when useful: `user`, `repo`, or `external`.
EOF
  fi

  if [ ! -e "$project_dir/.codex/config.toml" ]; then
    cat > "$project_dir/.codex/config.toml" <<EOF
# Repo-scoped Codex defaults seeded by cmux-codex-launcher.
# Keep secrets out of this file.

model = $(json_string "$CML_CODEX_MODEL")
model_reasoning_effort = $(json_string "$CML_CODEX_EFFORT")
plan_mode_reasoning_effort = $(json_string "$CML_CODEX_PLAN_EFFORT")

# Personal sandbox and approval defaults belong in ~/.codex/config.toml unless
# this repo has a clear reason to tighten or loosen them.
EOF
  fi
}

terminal_surface() {
  local name=$1
  local command=$2
  printf '{"type":"terminal","name":%s,"command":%s}' \
    "$(json_string "$name")" \
    "$(json_string "$command")"
}

browser_surface() {
  local name=$1
  local url=$2
  printf '{"type":"browser","name":%s,"url":%s}' \
    "$(json_string "$name")" \
    "$(json_string "$url")"
}

single_surface_layout() {
  local surface_json=$1
  printf '{"pane":{"surfaces":[%s]}}' "$surface_json"
}

split_preview_layout() {
  local left_surface_json=$1
  local preview_url=${2:-}
  local right_surface_json split

  if [ -z "$preview_url" ]; then
    single_surface_layout "$left_surface_json"
    return
  fi

  right_surface_json="$(browser_surface "preview" "$preview_url")"
  split="${CML_ROLE_PANE_SPLIT:-0.5}"
  printf '{"direction":"horizontal","split":%s,"children":[{"pane":{"surfaces":[%s]}},{"pane":{"surfaces":[%s]}}]}' \
    "$split" \
    "$left_surface_json" \
    "$right_surface_json"
}

build_role_prompt() {
  local role=$1
  local project_name=$2
  local project_dir=$3
  local session_file=$4
  local docs_text role_body selected_target github_repo

  docs_text="$(existing_doc_list "$project_dir" | sed 's/^/- /')"
  role_body="$(role_prompt_for "$role")"
  selected_target="${CML_SELECTED_TARGET:-}"
  github_repo="${CML_GITHUB_REPO:-}"

  cat <<EOF
Shared launcher context:
- Project name: $project_name
- Project directory: $project_dir
- Shared context file: $session_file
- Role: $role
- Selected target: ${selected_target:-unspecified}
- GitHub contribution target: ${github_repo:-use target repo origin}

Read first:
$docs_text

$role_body

Workflow:
- Use the shared context file for active task state.
- Read target-project AGENTS.md before editing.
- Confirm git status and origin before making repo-visible changes.
- Keep write scope narrow and disjoint from other roles.
- Report changed files, verification, risks, and next action.
- Ship completed work according to the target repo instructions, including commit/push rules.
- Do not add broad product modes, connectors, or unrelated refactors unless the user asks.
- Do not run cmux-codex-launcher or create another cmux workspace unless the user explicitly asks.
EOF
}

is_tty() {
  [ -t 0 ] && [ -t 1 ]
}

can_prompt() {
  is_tty || { : </dev/tty >/dev/tty; } 2>/dev/null
}

prompt_value() {
  local prompt=$1
  local default=${2:-}
  local value

  if ! can_prompt; then
    printf '%s' "$default"
    return
  fi

  if [ -n "$default" ]; then
    printf '%s [%s]: ' "$prompt" "$default" >/dev/tty
  else
    printf '%s: ' "$prompt" >/dev/tty
  fi
  IFS= read -r value </dev/tty
  printf '%s' "${value:-$default}"
}

confirm_yes() {
  local prompt=$1
  local value

  if ! can_prompt; then
    return 0
  fi

  printf '%s [Y/n]: ' "$prompt" >/dev/tty
  IFS= read -r value </dev/tty
  case "$value" in
    ''|[Yy]|[Yy][Ee][Ss]) return 0 ;;
    *) return 1 ;;
  esac
}

search_roots() {
  local roots=${CMUX_CODEX_SEARCH_ROOTS:-"$HOME/Desktop:$HOME/Projects:$HOME/src:$HOME/code"}
  local old_ifs=$IFS
  local root

  IFS=:
  for root in $roots; do
    IFS=$old_ifs
    [ -n "$root" ] || continue
    case "$root" in
      "~"*) root="$HOME${root#~}" ;;
    esac
    [ -d "$root" ] && printf '%s\n' "$root"
    IFS=:
  done
  IFS=$old_ifs
}

compact_search_text() {
  printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]'
}

is_subsequence() {
  local needle=$1
  local haystack=$2

  [ -n "$needle" ] && [ -n "$haystack" ] || return 1
  awk -v needle="$needle" -v haystack="$haystack" '
    BEGIN {
      cursor = 1
      for (i = 1; i <= length(needle); i++) {
        char = substr(needle, i, 1)
        found = 0
        for (; cursor <= length(haystack); cursor++) {
          if (substr(haystack, cursor, 1) == char) {
            found = 1
            cursor++
            break
          }
        }
        if (!found) {
          exit 1
        }
      }
      exit 0
    }
  '
}

score_candidate() {
  local query=$1
  local haystack=$2
  local query_lower haystack_lower word clean score compact_query compact_haystack

  query_lower="$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')"
  haystack_lower="$(printf '%s' "$haystack" | tr '[:upper:]' '[:lower:]')"
  compact_query="$(compact_search_text "$query")"
  compact_haystack="$(compact_search_text "$haystack")"
  score=0

  for word in $query_lower; do
    clean="$(printf '%s' "$word" | tr -cd '[:alnum:]_./-')"
    [ -n "$clean" ] || continue
    case "$haystack_lower" in
      *"$clean"*) score=$((score + ${#clean} + 20)) ;;
      *) score=$((score - 8)) ;;
    esac
  done

  if [ "${#compact_query}" -ge 3 ]; then
    case "$compact_haystack" in
      *"$compact_query"*) score=$((score + ${#compact_query} + 14)) ;;
      *)
        if is_subsequence "$compact_query" "$compact_haystack"; then
          score=$((score + ${#compact_query} + 6))
        fi
        ;;
    esac
  fi

  case "$haystack_lower" in
    "$query_lower"|*"/$query_lower"|*":$query_lower") score=$((score + 80)) ;;
  esac

  printf '%s' "$score"
}

candidate_line() {
  local score=$1
  local kind=$2
  local label=$3
  local path=$4
  local repo=${5:-}
  local url=${6:-}

  printf '%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$score" \
    "$(strip_tabs "$kind")" \
    "$(strip_tabs "$label")" \
    "$(strip_tabs "$path")" \
    "$(strip_tabs "$repo")" \
    "$(strip_tabs "$url")"
}

emit_local_repo_candidates() {
  local query=$1
  local root git_marker repo_dir label remote repo_ref score haystack
  local query_lower query_compact label_lower label_compact
  local depth=${CMUX_CODEX_SEARCH_DEPTH:-5}

  query_lower="$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')"
  query_compact="$(compact_search_text "$query")"

  search_roots | while IFS= read -r root; do
    find "$root" -maxdepth "$depth" \
      \( -name node_modules -o -name .Trash -o -name .cache -o -name Library -o -name .next -o -name dist -o -name build \) -prune \
      -o -name .git -print 2>/dev/null
  done | while IFS= read -r git_marker; do
    repo_dir="$(dirname "$git_marker")"
    [ -d "$repo_dir" ] || continue
    label="$(basename "$repo_dir")"
    remote="$(git -C "$repo_dir" remote get-url origin 2>/dev/null || true)"
    repo_ref="$(normalize_github_repo_ref "$remote" 2>/dev/null || true)"
    haystack="$label $repo_dir $repo_ref $remote"
    score="$(score_candidate "$query" "$haystack")"
    label_lower="$(printf '%s' "$label" | tr '[:upper:]' '[:lower:]')"
    if [ "$label_lower" = "$query_lower" ]; then
      score=$((score + 160))
    fi
    label_compact="$(compact_search_text "$label")"
    if [ "${#query_compact}" -ge 3 ] && is_subsequence "$query_compact" "$label_compact"; then
      score=$((score + 100 - ${#label_compact}))
    fi
    [ "$score" -gt 0 ] || continue
    candidate_line "$score" "local-repo" "$label" "$repo_dir" "$repo_ref" "$remote"
  done
}

emit_file_candidates() {
  local query=$1
  local first root file project_dir repo_ref rel score haystack
  local depth=${CMUX_CODEX_FILE_SEARCH_DEPTH:-6}
  local fuzzy_limit=${CMUX_CODEX_FILE_FUZZY_LIMIT:-500}

  first="$(printf '%s' "$query" | awk '{print $1}')"
  first="$(printf '%s' "$first" | tr -cd '[:alnum:]_.-')"
  [ -n "$first" ] || return 0

  search_roots | while IFS= read -r root; do
    find "$root" -maxdepth "$depth" \
      \( -name node_modules -o -name .git -o -name .Trash -o -name .cache -o -name Library -o -name .next -o -name dist -o -name build \) -prune \
      -o -type f -iname "*$first*" -print 2>/dev/null | head -n 20
  done | while IFS= read -r file; do
    project_dir="$(git -C "$(dirname "$file")" rev-parse --show-toplevel 2>/dev/null || dirname "$file")"
    repo_ref="$(git_origin_ref_for "$project_dir" 2>/dev/null || true)"
    rel="${file#$project_dir/}"
    haystack="$rel $file $project_dir $repo_ref"
    score="$(score_candidate "$query" "$haystack")"
    score=$((score - 20))
    [ "$score" -gt 0 ] || continue
    candidate_line "$score" "file" "$rel" "$file" "$repo_ref" "$project_dir"
  done

  case "$query" in
    *" "* ) ;;
    * )
      [ "${CMUX_CODEX_FUZZY_FILES:-false}" = "true" ] || return 0
      ;;
  esac

  command -v rg >/dev/null 2>&1 || return 0
  search_roots | while IFS= read -r root; do
    (
      cd "$root" || exit 0
      rg --files \
        -g '!node_modules/**' \
        -g '!.git/**' \
        -g '!.next/**' \
        -g '!dist/**' \
        -g '!build/**' 2>/dev/null | head -n "$fuzzy_limit" | sed "s#^#$root/#"
    )
  done | while IFS= read -r file; do
    [ -f "$file" ] || continue
    project_dir="$(git -C "$(dirname "$file")" rev-parse --show-toplevel 2>/dev/null || dirname "$file")"
    repo_ref="$(git_origin_ref_for "$project_dir" 2>/dev/null || true)"
    rel="${file#$project_dir/}"
    haystack="$rel $file $project_dir $repo_ref"
    score="$(score_candidate "$query" "$haystack")"
    score=$((score - 20))
    [ "$score" -gt 0 ] || continue
    candidate_line "$score" "file" "$rel" "$file" "$repo_ref" "$project_dir"
  done
}

emit_github_candidates() {
  local query=$1
  local limit=${CMUX_CODEX_GITHUB_LIMIT:-200}
  local owner repo_ref url ssh_url description score haystack
  local query_lower query_compact repo_name_lower repo_name_compact

  query_lower="$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')"
  query_compact="$(compact_search_text "$query")"

  command -v gh >/dev/null 2>&1 || return 0
  owner="$(gh api user --jq .login 2>/dev/null || true)"
  [ -n "$owner" ] || return 0

  gh repo list "$owner" --limit "$limit" --json nameWithOwner,url,sshUrl,description \
    --jq '.[] | [.nameWithOwner,.url,.sshUrl,(.description // "")] | @tsv' 2>/dev/null |
    while IFS=$'\t' read -r repo_ref url ssh_url description; do
      haystack="$repo_ref $url $description"
      score="$(score_candidate "$query" "$haystack")"
      repo_name_lower="$(printf '%s' "${repo_ref##*/}" | tr '[:upper:]' '[:lower:]')"
      if [ "$repo_name_lower" = "$query_lower" ]; then
        score=$((score + 120))
      fi
      repo_name_compact="$(compact_search_text "${repo_ref##*/}")"
      if [ "${#query_compact}" -ge 3 ] && is_subsequence "$query_compact" "$repo_name_compact"; then
        score=$((score + 80 - ${#repo_name_compact}))
      fi
      [ "$score" -gt 0 ] || continue
      candidate_line "$score" "github-repo" "$repo_ref" "$repo_ref" "$repo_ref" "${ssh_url:-$url}"
    done
}

collect_candidates() {
  local query=$1
  {
    emit_local_repo_candidates "$query"
    emit_file_candidates "$query"
    emit_github_candidates "$query"
  } | awk -F '\t' '!seen[$2 "\t" $4 "\t" $5]++' | sort -rn
}

direct_path_candidate() {
  local query=$1
  local path=$query
  local project_dir repo_ref label

  case "$path" in
    "~"*) path="$HOME${path#~}" ;;
  esac
  [ -e "$path" ] || return 1

  if [ -d "$path" ]; then
    project_dir="$(git -C "$path" rev-parse --show-toplevel 2>/dev/null || true)"
    if [ -z "$project_dir" ]; then
      project_dir="$(cd "$path" && pwd)"
    fi
    label="$(basename "$project_dir")"
    repo_ref="$(git_origin_ref_for "$project_dir" 2>/dev/null || true)"
    candidate_line 200 "local-repo" "$label" "$project_dir" "$repo_ref" "$project_dir"
  else
    project_dir="$(git -C "$(dirname "$path")" rev-parse --show-toplevel 2>/dev/null || dirname "$path")"
    repo_ref="$(git_origin_ref_for "$project_dir" 2>/dev/null || true)"
    candidate_line 200 "file" "${path#$project_dir/}" "$path" "$repo_ref" "$project_dir"
  fi
}

choose_candidate() {
  local query=$1
  local candidates_file=$2
  local choice max line score kind label path repo url index

  if ! is_tty; then
    sed -n '1p' "$candidates_file"
    return
  fi

  printf '\nMatches for "%s":\n' "$query" >&2
  index=1
  while IFS=$'\t' read -r score kind label path repo url; do
    [ "$index" -le 8 ] || break
    printf '  %s) %s  %s' "$index" "$kind" "$label" >&2
    [ -n "$repo" ] && printf '  [%s]' "$repo" >&2
    printf '\n      %s\n' "$path" >&2
    index=$((index + 1))
  done < "$candidates_file"
  max=$((index - 1))
  [ "$max" -gt 0 ] || return 1

  choice="$(prompt_value "Choose a match" "1")"
  case "$choice" in
    ''|*[!0-9]*) choice=1 ;;
  esac
  [ "$choice" -ge 1 ] && [ "$choice" -le "$max" ] || choice=1
  sed -n "${choice}p" "$candidates_file"
}

local_project_for_github_ref() {
  local target_ref=$1
  local root git_marker repo_dir repo_ref
  local depth=${CMUX_CODEX_SEARCH_DEPTH:-5}

  search_roots | while IFS= read -r root; do
    find "$root" -maxdepth "$depth" \
      \( -name node_modules -o -name .Trash -o -name .cache -o -name Library -o -name .next -o -name dist -o -name build \) -prune \
      -o -name .git -print 2>/dev/null
  done | while IFS= read -r git_marker; do
    repo_dir="$(dirname "$git_marker")"
    repo_ref="$(git_origin_ref_for "$repo_dir" 2>/dev/null || true)"
    if [ "$repo_ref" = "$target_ref" ]; then
      printf '%s\n' "$repo_dir"
      return 0
    fi
  done | sed -n '1p'
}

clone_or_resolve_github_repo() {
  local repo_ref=$1
  local existing clone_root dest

  existing="$(local_project_for_github_ref "$repo_ref")"
  if [ -n "$existing" ]; then
    printf '%s' "$existing"
    return 0
  fi

  clone_root="${CMUX_CODEX_PROJECTS_DIR:-$HOME/Desktop}"
  dest="$clone_root/$(basename "$repo_ref")"
  if [ -d "$dest" ]; then
    printf '%s' "$dest"
    return 0
  fi

  if [ "$CLONE_MISSING_GITHUB" -ne 1 ]; then
    die "GitHub repo is not cloned locally: $repo_ref"
  fi
  if [ "$DRY_RUN" -eq 1 ]; then
    die "GitHub repo is not cloned locally: $repo_ref (dry run will not clone)"
  fi

  command -v gh >/dev/null 2>&1 || die "gh is required to clone $repo_ref"
  mkdir -p "$clone_root"
  gh repo clone "$repo_ref" "$dest"
  printf '%s' "$dest"
}

profile_for_project_dir() {
  local project_dir=$1
  local profile_dir path name resolved_dir

  for profile_dir in "$LAUNCHER_HOME/profiles" "$REPO_DIR/profiles"; do
    [ -d "$profile_dir" ] || continue
    for path in "$profile_dir"/*.env; do
      [ -f "$path" ] || continue
      resolved_dir="$(CML_PROJECT_DIR=; source "$path"; [ -n "${CML_PROJECT_DIR:-}" ] && cd "$CML_PROJECT_DIR" 2>/dev/null && pwd || true)"
      if [ "$resolved_dir" = "$project_dir" ]; then
        name="$(basename "$path" .env)"
        printf '%s\t%s' "$name" "$path"
        return 0
      fi
    done
  done
  return 1
}

infer_package_manager() {
  local project_dir=$1
  if [ -f "$project_dir/pnpm-lock.yaml" ]; then
    printf 'pnpm'
  elif [ -f "$project_dir/bun.lockb" ] || [ -f "$project_dir/bun.lock" ]; then
    printf 'bun'
  elif [ -f "$project_dir/yarn.lock" ]; then
    printf 'yarn'
  else
    printf 'npm'
  fi
}

package_has_script() {
  local project_dir=$1
  local script=$2
  [ -f "$project_dir/package.json" ] || return 1
  command -v node >/dev/null 2>&1 || return 1
  node -e "const p=require(process.argv[1]); process.exit(p.scripts && p.scripts[process.argv[2]] ? 0 : 1)" "$project_dir/package.json" "$script" >/dev/null 2>&1
}

script_command_for() {
  local project_dir=$1
  local script=$2
  local manager

  manager="$(infer_package_manager "$project_dir")"
  case "$manager" in
    npm) printf 'npm run %s' "$script" ;;
    yarn) printf 'yarn %s' "$script" ;;
    bun) printf 'bun run %s' "$script" ;;
    *) printf '%s %s' "$manager" "$script" ;;
  esac
}

infer_dev_command() {
  local project_dir=$1
  local command

  if package_has_script "$project_dir" dev; then
    command="$(script_command_for "$project_dir" dev)"
    printf 'if lsof -nP -iTCP:3000 -sTCP:LISTEN >/dev/null 2>&1; then printf "Dev server may already be running at http://localhost:3000\\n"; exec "${SHELL:-/bin/zsh}" -l; fi; %s' "$command"
  elif [ -f "$project_dir/pyproject.toml" ] || [ -f "$project_dir/requirements.txt" ]; then
    printf 'printf "Python project detected. Start the app-specific dev server here after reading the README.\\n"; exec "${SHELL:-/bin/zsh}" -l'
  else
    printf ''
  fi
}

infer_preview_url() {
  local project_dir=$1

  if package_has_script "$project_dir" dev; then
    printf 'http://localhost:3000'
  else
    printf ''
  fi
}

apply_dynamic_profile() {
  local project_dir=$1
  local selected_target=$2
  local github_repo=$3
  local project_base dev_command preview_url

  project_base="$(basename "$project_dir")"
  dev_command="$(infer_dev_command "$project_dir")"
  preview_url="$(infer_preview_url "$project_dir")"

  CML_PROJECT_DIR="$project_dir"
  CML_PROJECT_NAME="${NAME_OVERRIDE:-$project_base}"
  CML_WORKSPACE_NAME="${WORKSPACE_OVERRIDE:-$CML_PROJECT_NAME Cockpit}"
  if [ "$CODEX_APP_FIRST" -eq 1 ]; then
    CML_WORKSPACE_DESCRIPTION="Codex app launch for $CML_PROJECT_NAME"
  else
    CML_WORKSPACE_DESCRIPTION="One-click cmux Codex cockpit for $CML_PROJECT_NAME"
  fi
  CML_PREVIEW_URL="${PREVIEW_OVERRIDE:-$preview_url}"
  CML_DEV_COMMAND="${DEV_COMMAND_OVERRIDE:-$dev_command}"
  CML_PLAN_DOC="README.md"
  CML_CODEX_MODEL="gpt-5.5"
  CML_CODEX_EFFORT="medium"
  CML_CODEX_PLAN_EFFORT="high"
  CML_SANDBOX="danger-full-access"
  CML_APPROVAL="never"
  CML_OPEN_CODEX_APP="true"
  CML_AUTOSTART_ROLES="false"
  CML_ROLE_NAMES=("lead" "build" "verify" "ship")
  CML_ROLE_PROMPT_LEAD="Read AGENTS.md and README.md first when present. You coordinate this project launch around the selected target and GitHub repo. Keep scope tight, assign workstreams clearly, preserve user changes, and keep the work pointed at the requested ship outcome."
  CML_ROLE_PROMPT_BUILD="Read AGENTS.md and README.md first when present. You own the implementation workstream for the selected target. Make the smallest coherent code change, keep git status clean, and avoid unrelated refactors."
  CML_ROLE_PROMPT_VERIFY="Read AGENTS.md and README.md first when present. You own verification. Identify the project’s correct checks, run the narrowest useful tests first, then broaden only when the risk requires it."
  CML_ROLE_PROMPT_SHIP="Read AGENTS.md and README.md first when present. You own shipping hygiene: inspect branch, origin, changed files, verification status, and make sure completed repo-visible work is committed and pushed according to the target repo instructions."
  CML_SELECTED_TARGET="$selected_target"
  CML_GITHUB_REPO="$github_repo"
}

ensure_origin_for_github_repo() {
  local project_dir=$1
  local github_repo=$2
  local existing

  [ -n "$github_repo" ] || return 0
  git -C "$project_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0
  existing="$(git -C "$project_dir" remote get-url origin 2>/dev/null || true)"
  [ -z "$existing" ] || return 0
  [ "$DRY_RUN" -eq 1 ] && return 0
  git -C "$project_dir" remote add origin "$(github_ssh_url "$github_repo")"
}

select_github_repo() {
  local default_repo=$1
  local input tmp line score kind label path repo url

  input="$GITHUB_OVERRIDE"
  if [ -z "$input" ] && [ -n "$default_repo" ]; then
    if confirm_yes "Use GitHub repo $default_repo as the contribution target?"; then
      printf '%s' "$default_repo"
      return 0
    fi
  fi

  if [ -z "$input" ]; then
    input="$(prompt_value "Which GitHub repo should this contribute to?" "$default_repo")"
  fi

  if [ -z "$input" ]; then
    printf ''
    return 0
  fi

  repo="$(normalize_github_repo_ref "$input" 2>/dev/null || true)"
  if [ -n "$repo" ]; then
    printf '%s' "$repo"
    return 0
  fi

  tmp="$(mktemp -t cmux-codex-github.XXXXXX)"
  emit_github_candidates "$input" > "$tmp"
  if [ ! -s "$tmp" ]; then
    rm -f "$tmp"
    die "no GitHub repo matched: $input"
  fi

  line="$(choose_candidate "$input" "$tmp")"
  rm -f "$tmp"
  IFS=$'\t' read -r score kind label path repo url <<EOF
$line
EOF
  printf '%s' "$repo"
}

run_picker() {
  local query candidate_file line score kind label path repo url project_dir selected_target
  local default_repo github_repo matched_profile matched_name matched_path

  query="$PICKER_QUERY"
  if [ -z "$query" ]; then
    query="$(prompt_value "What project, file, app, folder, or GitHub repo are you working on?" "")"
  fi
  [ -n "$query" ] || die "nothing to launch"

  candidate_file="$(mktemp -t cmux-codex-candidates.XXXXXX)"
  direct_path_candidate "$query" > "$candidate_file" 2>/dev/null || true
  collect_candidates "$query" >> "$candidate_file"
  sort -rn "$candidate_file" | awk -F '\t' '!seen[$2 "\t" $4 "\t" $5]++' > "$candidate_file.sorted"
  mv "$candidate_file.sorted" "$candidate_file"

  [ -s "$candidate_file" ] || die "no local files or GitHub repos matched: $query"
  line="$(choose_candidate "$query" "$candidate_file")"
  rm -f "$candidate_file"

  IFS=$'\t' read -r score kind label path repo url <<EOF
$line
EOF

  case "$kind" in
    file)
      selected_target="$path"
      project_dir="$(git -C "$(dirname "$path")" rev-parse --show-toplevel 2>/dev/null || dirname "$path")"
      default_repo="$repo"
      ;;
    local-repo)
      selected_target="$path"
      project_dir="$path"
      default_repo="${repo:-$(git_origin_ref_for "$path" 2>/dev/null || true)}"
      ;;
    github-repo)
      selected_target="$repo"
      project_dir="$(clone_or_resolve_github_repo "$repo")"
      default_repo="$repo"
      ;;
    *)
      die "unknown picker match kind: $kind"
      ;;
  esac

  project_dir="$(cd "$project_dir" && pwd)"
  github_repo="$(select_github_repo "$default_repo")"
  ensure_origin_for_github_repo "$project_dir" "$github_repo"

  matched_profile="$(profile_for_project_dir "$project_dir" || true)"
  if [ -n "$matched_profile" ]; then
    IFS=$'\t' read -r matched_name matched_path <<EOF
$matched_profile
EOF
    PROFILE="$matched_name"
    PROFILE_PATH="$matched_path"
    # shellcheck source=/dev/null
    source "$PROFILE_PATH"
    CML_SELECTED_TARGET="$selected_target"
    CML_GITHUB_REPO="$github_repo"
  else
    PROFILE="dynamic"
    PROFILE_PATH="interactive"
    apply_dynamic_profile "$project_dir" "$selected_target" "$github_repo"
  fi
}

plan_surface_for() {
  local project_name=$1
  local project_dir=$2
  local session_file=$3
  local plan_doc=${CML_PLAN_DOC:-}
  local q_session_file q_plan_path plan_command

  q_session_file="$(shell_quote "$session_file")"

  if [ -n "$plan_doc" ] && [ -f "$project_dir/$plan_doc" ]; then
    q_plan_path="$(shell_quote "$project_dir/$plan_doc")"
    plan_command="printf 'Plan doc: %s\\nShared context: %s\\n\\nOpen the formatted markdown panel after launch with:\\n  cmux markdown open %s --workspace \"\$CMUX_WORKSPACE_ID\" --direction right --focus false\\n\\n' $(shell_quote "$plan_doc") $q_session_file $q_plan_path; exec \"\${SHELL:-/bin/zsh}\" -l"
  else
    plan_command="printf 'Shared context: %s\\n' $q_session_file; printf 'No plan doc configured.\\n'; exec \"\${SHELL:-/bin/zsh}\" -l"
  fi

  terminal_surface "plan" "$plan_command"
}

role_surface_for() {
  local role=$1
  local project_name=$2
  local project_dir=$3
  local session_file=$4
  local q_project_dir q_session_file q_model q_config q_plan_config q_sandbox q_approval
  local role_prompt role_command

  q_project_dir="$(shell_quote "$project_dir")"
  q_session_file="$(shell_quote "$session_file")"
  q_model="$(shell_quote "$CML_CODEX_MODEL")"
  q_config="$(shell_quote "model_reasoning_effort=\"$CML_CODEX_EFFORT\"")"
  q_plan_config="$(shell_quote "plan_mode_reasoning_effort=\"$CML_CODEX_PLAN_EFFORT\"")"
  q_sandbox="$(shell_quote "$CML_SANDBOX")"
  q_approval="$(shell_quote "$CML_APPROVAL")"

  role_prompt="$(build_role_prompt "$role" "$project_name" "$project_dir" "$session_file")"
  if [ "$CML_AUTOSTART_ROLES" = "true" ]; then
    role_command="codex -C $q_project_dir -m $q_model -c $q_config -c $q_plan_config -s $q_sandbox -a $q_approval $(shell_quote "$role_prompt")"
  else
    role_command="printf 'Role: %s\\nProject: %s\\nShared context: %s\\nSelected target: %s\\nGitHub target: %s\\nReasoning: %s\\nPlan mode: %s\\n\\nCodex opens idle here to avoid unintended background work. Paste the task when you want this role to start.\\n\\n' $(shell_quote "$role") $(shell_quote "$project_dir") $q_session_file $(shell_quote "${CML_SELECTED_TARGET:-unspecified}") $(shell_quote "${CML_GITHUB_REPO:-use target repo origin}") $(shell_quote "$CML_CODEX_EFFORT") $(shell_quote "$CML_CODEX_PLAN_EFFORT"); exec codex -C $q_project_dir -m $q_model -c $q_config -c $q_plan_config -s $q_sandbox -a $q_approval"
  fi

  terminal_surface "$role" "$role_command"
}

workspace_entry_json() {
  local name=$1
  local description=$2
  local layout_json=$3

  printf '{"name":%s,"description":%s,"layout":%s}' \
    "$(json_string "$name")" \
    "$(json_string "$description")" \
    "$layout_json"
}

build_workspace_plan() {
  local project_name=$1
  local project_dir=$2
  local session_file=$3
  local role surface layout dev_command entries_json
  local -a entries=()

  for role in "${CML_ROLE_NAMES[@]}"; do
    surface="$(role_surface_for "$role" "$project_name" "$project_dir" "$session_file")"
    layout="$(split_preview_layout "$surface" "${CML_PREVIEW_URL:-}")"
    entries+=("$(workspace_entry_json "$project_name: $role" "$CML_WORKSPACE_DESCRIPTION" "$layout")")
  done

  dev_command="${CML_DEV_COMMAND:-}"
  if [ -n "$dev_command" ]; then
    surface="$(terminal_surface "dev-server" "$dev_command")"
    layout="$(single_surface_layout "$surface")"
    entries+=("$(workspace_entry_json "$project_name: dev-server" "Development server for $project_name" "$layout")")
  fi

  entries_json="$(join_comma "${entries[@]}")"
  printf '{"mode":"sidebar","workspaces":[%s]}' "$entries_json"
}

build_layout() {
  local project_name=$1
  local project_dir=$2
  local session_file=$3
  local role dev_command surfaces_json
  local -a surfaces=()

  surfaces+=("$(plan_surface_for "$project_name" "$project_dir" "$session_file")")

  for role in "${CML_ROLE_NAMES[@]}"; do
    surfaces+=("$(role_surface_for "$role" "$project_name" "$project_dir" "$session_file")")
  done

  dev_command="${CML_DEV_COMMAND:-}"
  if [ -n "$dev_command" ]; then
    surfaces+=("$(terminal_surface "dev-server" "$dev_command")")
  fi
  if [ -n "${CML_PREVIEW_URL:-}" ]; then
    surfaces+=("$(browser_surface "preview" "$CML_PREVIEW_URL")")
  fi

  surfaces_json="$(join_comma "${surfaces[@]}")"
  printf '{"pane":{"surfaces":[%s]}}' "$surfaces_json"
}

launch_sidebar_workspaces() {
  local project_name=$1
  local project_dir=$2
  local session_file=$3
  local role surface layout dev_command i focus

  dev_command="${CML_DEV_COMMAND:-}"
  if [ -n "$dev_command" ]; then
    surface="$(terminal_surface "dev-server" "$dev_command")"
    layout="$(single_surface_layout "$surface")"
    cmux new-workspace \
      --name "$project_name: dev-server" \
      --description "Development server for $project_name" \
      --cwd "$project_dir" \
      --layout "$layout" \
      --focus false
  fi

  for ((i = ${#CML_ROLE_NAMES[@]} - 1; i >= 0; i--)); do
    role="${CML_ROLE_NAMES[$i]}"
    surface="$(role_surface_for "$role" "$project_name" "$project_dir" "$session_file")"
    layout="$(split_preview_layout "$surface" "${CML_PREVIEW_URL:-}")"
    if [ "$i" -eq 0 ]; then
      focus="$FOCUS_WORKSPACE"
    else
      focus=false
    fi
    cmux new-workspace \
      --name "$project_name: $role" \
      --description "$CML_WORKSPACE_DESCRIPTION" \
      --cwd "$project_dir" \
      --layout "$layout" \
      --focus "$focus"
  done
}

load_last_state() {
  [ -f "$LAST_STATE" ] || die "no last launch state at $LAST_STATE"
  # shellcheck source=/dev/null
  source "$LAST_STATE"
  PROFILE="${CML_LAST_PROFILE:-$PROFILE}"
  PROJECT_OVERRIDE="${CML_LAST_PROJECT_DIR:-$PROJECT_OVERRIDE}"
}

save_last_state() {
  local project_dir=$1
  mkdir -p "$STATE_DIR"
  {
    printf 'CML_LAST_PROFILE=%s\n' "$(shell_quote "$PROFILE")"
    printf 'CML_LAST_PROJECT_DIR=%s\n' "$(shell_quote "$project_dir")"
    printf 'CML_LAST_LAUNCHED_AT=%s\n' "$(shell_quote "$(date -u +%Y-%m-%dT%H:%M:%SZ)")"
  } > "$LAST_STATE"
}

open_codex_app() {
  local project_dir=$1
  if command -v codex >/dev/null 2>&1; then
    codex app \
      -c "model=\"$CML_CODEX_MODEL\"" \
      -c "model_reasoning_effort=\"$CML_CODEX_EFFORT\"" \
      -c "plan_mode_reasoning_effort=\"$CML_CODEX_PLAN_EFFORT\"" \
      "$project_dir" >/dev/null 2>&1 &
    return 0
  fi
  open -a Codex "$project_dir" >/dev/null 2>&1 &
}

show_feed_sidebar() {
  [ "${CML_SHOW_FEED_SIDEBAR:-true}" = "true" ] || return 0
  command -v cmux >/dev/null 2>&1 || return 0
  cmux right-sidebar set feed --no-focus >/dev/null 2>&1 || true
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --profile)
      shift; [ "$#" -gt 0 ] || die "missing profile"
      PROFILE="$1"
      PROFILE_EXPLICIT=1
      ;;
    --project)
      shift; [ "$#" -gt 0 ] || die "missing project path"
      PROJECT_OVERRIDE="$1"
      ;;
    --name)
      shift; [ "$#" -gt 0 ] || die "missing project name"
      NAME_OVERRIDE="$1"
      ;;
    --workspace-name)
      shift; [ "$#" -gt 0 ] || die "missing workspace name"
      WORKSPACE_OVERRIDE="$1"
      ;;
    --preview-url)
      shift; [ "$#" -gt 0 ] || die "missing preview URL"
      PREVIEW_OVERRIDE="$1"
      ;;
    --dev-command)
      shift; [ "$#" -gt 0 ] || die "missing dev command"
      DEV_COMMAND_OVERRIDE="$1"
      ;;
    --choose|--interactive)
      INTERACTIVE_PICKER=1
      ;;
    --query)
      shift; [ "$#" -gt 0 ] || die "missing query"
      PICKER_QUERY="$1"
      ;;
    --github)
      shift; [ "$#" -gt 0 ] || die "missing GitHub repo"
      GITHUB_OVERRIDE="$1"
      ;;
    --no-clone)
      CLONE_MISSING_GITHUB=0
      ;;
    --codex|--codex-app)
      CODEX_APP_FIRST=1
      CREATE_CMUX=0
      OPEN_CODEX_APP_OVERRIDE="true"
      SEED_CODEX_FILES=1
      ;;
    --seed-codex-files)
      SEED_CODEX_FILES=1
      ;;
    --no-seed-codex-files)
      SEED_CODEX_FILES=0
      ;;
    --reset-task)
      RESET_TASK_CONTEXT=1
      ;;
    --app)
      OPEN_CODEX_APP_OVERRIDE="true"
      ;;
    --no-app)
      OPEN_CODEX_APP_OVERRIDE="false"
      ;;
    --autostart-roles)
      AUTOSTART_ROLES_OVERRIDE="true"
      ;;
    --no-autostart-roles)
      AUTOSTART_ROLES_OVERRIDE="false"
      ;;
    --no-cmux)
      CREATE_CMUX=0
      ;;
    --dry-run)
      DRY_RUN=1
      ;;
    --print-layout)
      PRINT_LAYOUT=1
      ;;
    --resume-last)
      RESUME_LAST=1
      ;;
    --status-last)
      STATUS_LAST=1
      ;;
    --no-focus)
      FOCUS_WORKSPACE="false"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown argument: $1"
      ;;
  esac
  shift
done

if [ "$STATUS_LAST" -eq 1 ]; then
  if [ -f "$LAST_STATE" ]; then
    cat "$LAST_STATE"
  else
    printf 'No last launch state at %s\n' "$LAST_STATE"
  fi
  exit 0
fi

if [ "$RESUME_LAST" -eq 1 ]; then
  load_last_state
fi

if [ "$CODEX_APP_FIRST" -eq 1 ] && [ "$PROFILE_EXPLICIT" -eq 0 ] && [ -z "$PROJECT_OVERRIDE" ] && [ "$RESUME_LAST" -eq 0 ]; then
  INTERACTIVE_PICKER=1
fi
if [ "$CODEX_APP_FIRST" -eq 1 ] && [ -n "$PICKER_QUERY" ]; then
  INTERACTIVE_PICKER=1
fi

if [ "$INTERACTIVE_PICKER" -eq 1 ]; then
  run_picker
elif [ "$CODEX_APP_FIRST" -eq 1 ] && [ "$PROFILE_EXPLICIT" -eq 0 ] && [ -n "$PROJECT_OVERRIDE" ]; then
  PROJECT_OVERRIDE="$(cd "$PROJECT_OVERRIDE" && pwd)" || die "project dir not found: $PROJECT_OVERRIDE"
  PROFILE="dynamic"
  PROFILE_PATH="direct-project"
  CML_GITHUB_REPO="$(git_origin_ref_for "$PROJECT_OVERRIDE" 2>/dev/null || true)"
  if [ -n "$GITHUB_OVERRIDE" ]; then
    CML_GITHUB_REPO="$(normalize_github_repo_ref "$GITHUB_OVERRIDE" 2>/dev/null || true)"
  fi
  apply_dynamic_profile "$PROJECT_OVERRIDE" "$PROJECT_OVERRIDE" "$CML_GITHUB_REPO"
else
  PROFILE_PATH="$(profile_path_for "$PROFILE" || true)"
  [ -n "${PROFILE_PATH:-}" ] || die "profile not found: $PROFILE"
  # shellcheck source=/dev/null
  source "$PROFILE_PATH"
fi

CML_PROJECT_DIR="${PROJECT_OVERRIDE:-${CML_PROJECT_DIR:-$PWD}}"
CML_PROJECT_NAME="${NAME_OVERRIDE:-${CML_PROJECT_NAME:-$(basename "$CML_PROJECT_DIR")}}"
CML_WORKSPACE_NAME="${WORKSPACE_OVERRIDE:-${CML_WORKSPACE_NAME:-$CML_PROJECT_NAME}}"
CML_WORKSPACE_DESCRIPTION="${CML_WORKSPACE_DESCRIPTION:-cmux Codex workspace for $CML_PROJECT_NAME}"
CML_PREVIEW_URL="${PREVIEW_OVERRIDE:-${CML_PREVIEW_URL:-}}"
CML_DEV_COMMAND="${DEV_COMMAND_OVERRIDE:-${CML_DEV_COMMAND:-}}"
CML_PLAN_DOC="${CML_PLAN_DOC:-README.md}"
CML_ROLE_PANE_SPLIT="${CML_ROLE_PANE_SPLIT:-0.5}"
CML_CODEX_MODEL="${CML_CODEX_MODEL:-gpt-5.5}"
CML_CODEX_EFFORT="${CML_CODEX_EFFORT:-medium}"
CML_CODEX_PLAN_EFFORT="${CML_CODEX_PLAN_EFFORT:-high}"
CML_SANDBOX="${CML_SANDBOX:-workspace-write}"
CML_APPROVAL="${CML_APPROVAL:-on-request}"
CML_OPEN_CODEX_APP="${OPEN_CODEX_APP_OVERRIDE:-${CML_OPEN_CODEX_APP:-true}}"
CML_AUTOSTART_ROLES="${AUTOSTART_ROLES_OVERRIDE:-${CML_AUTOSTART_ROLES:-false}}"
CML_SHOW_FEED_SIDEBAR="${CML_SHOW_FEED_SIDEBAR:-true}"
CML_WORKSPACE_MODE="${CML_WORKSPACE_MODE:-sidebar}"

if [ "${#CML_ROLE_NAMES[@]}" -eq 0 ]; then
  CML_ROLE_NAMES=("lead" "build" "verify")
fi

CML_PROJECT_DIR="$(cd "$CML_PROJECT_DIR" && pwd)"
[ -d "$CML_PROJECT_DIR" ] || die "project dir not found: $CML_PROJECT_DIR"

SESSION_FILE="$(create_shared_context "$CML_PROJECT_NAME" "$CML_PROJECT_DIR")"
update_shared_context_selection "$SESSION_FILE" "$CML_PROJECT_NAME" "$CML_PROJECT_DIR"
if [ "$RESET_TASK_CONTEXT" -eq 1 ] && [ "$DRY_RUN" -ne 1 ]; then
  reset_shared_context_task "$SESSION_FILE"
fi
if [ "$CML_WORKSPACE_MODE" = "tabs" ]; then
  LAYOUT_JSON="$(build_layout "$CML_PROJECT_NAME" "$CML_PROJECT_DIR" "$SESSION_FILE")"
else
  LAYOUT_JSON="$(build_workspace_plan "$CML_PROJECT_NAME" "$CML_PROJECT_DIR" "$SESSION_FILE")"
fi

if [ "$PRINT_LAYOUT" -eq 1 ]; then
  printf '%s\n' "$LAYOUT_JSON"
  exit 0
fi

if [ "$DRY_RUN" -eq 1 ]; then
  cat <<EOF
profile: $PROFILE
profile_path: $PROFILE_PATH
project: $CML_PROJECT_NAME
project_dir: $CML_PROJECT_DIR
workspace: $CML_WORKSPACE_NAME
codex_app: $CML_OPEN_CODEX_APP
cmux_workspace: $CREATE_CMUX
codex_app_first: $CODEX_APP_FIRST
seed_codex_files: $SEED_CODEX_FILES
reset_task: $RESET_TASK_CONTEXT
autostart_roles: $CML_AUTOSTART_ROLES
feed_sidebar: $CML_SHOW_FEED_SIDEBAR
workspace_mode: $CML_WORKSPACE_MODE
model: $CML_CODEX_MODEL
effort: $CML_CODEX_EFFORT
plan_effort: $CML_CODEX_PLAN_EFFORT
sandbox: $CML_SANDBOX
approval: $CML_APPROVAL
preview: ${CML_PREVIEW_URL:-none}
dev_command: ${CML_DEV_COMMAND:-none}
selected_target: ${CML_SELECTED_TARGET:-none}
github_repo: ${CML_GITHUB_REPO:-none}
shared_context: $SESSION_FILE
codex_workflow_files:
  - AGENTS.md
  - docs/agent-workflow.md
  - docs/queue.md
  - docs/knowledge.md
  - .codex/config.toml
docs:
$(existing_doc_list "$CML_PROJECT_DIR" | sed 's/^/  - /')
roles:
$(printf '%s\n' "${CML_ROLE_NAMES[@]}" | sed 's/^/  - /')
layout:
$LAYOUT_JSON
EOF
  exit 0
fi

if [ "$SEED_CODEX_FILES" -eq 1 ]; then
  seed_codex_project_files "$CML_PROJECT_NAME" "$CML_PROJECT_DIR"
fi

save_last_state "$CML_PROJECT_DIR"

if [ "$CML_OPEN_CODEX_APP" = "true" ]; then
  open_codex_app "$CML_PROJECT_DIR"
fi

if [ "$CREATE_CMUX" -eq 1 ]; then
  command -v cmux >/dev/null 2>&1 || die "cmux is not installed or not on PATH"
  if [ "$CML_WORKSPACE_MODE" = "tabs" ]; then
    cmux new-workspace \
      --name "$CML_WORKSPACE_NAME" \
      --description "$CML_WORKSPACE_DESCRIPTION" \
      --cwd "$CML_PROJECT_DIR" \
      --layout "$LAYOUT_JSON" \
      --focus "$FOCUS_WORKSPACE"
  else
    launch_sidebar_workspaces "$CML_PROJECT_NAME" "$CML_PROJECT_DIR" "$SESSION_FILE"
  fi
  show_feed_sidebar
fi
