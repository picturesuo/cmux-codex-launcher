{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  "actions": {
    "choose-codex-cockpit": {
      "type": "command",
      "title": "Choose Codex Cockpit",
      "subtitle": "Search files and GitHub, then launch the right cmux workspace",
      "command": "bin/cmux-codex-launcher --choose",
      "target": "newTabInCurrentPane",
      "palette": true,
      "icon": {
        "type": "symbol",
        "name": "magnifyingglass.circle"
      }
    },
    "open-penny-cockpit": {
      "type": "command",
      "title": "Open Penny Cockpit",
      "subtitle": "Launch Penny in cmux and Codex app",
      "command": "bin/cmux-codex-launcher --profile penny",
      "target": "newTabInCurrentPane",
      "palette": true,
      "icon": {
        "type": "symbol",
        "name": "square.stack.3d.up"
      }
    }
  },
  "ui": {
    "newWorkspace": {
      "action": "choose-codex-cockpit",
      "contextMenu": [
        {
          "action": "choose-codex-cockpit",
          "title": "Choose Codex Cockpit"
        },
        {
          "action": "open-penny-cockpit",
          "title": "Open Penny Cockpit"
        },
        {
          "type": "separator"
        },
        {
          "action": "cmux.newTerminal",
          "title": "New Terminal"
        },
        {
          "action": "cmux.newBrowser",
          "title": "New Browser"
        }
      ]
    }
  },
  "commands": [
    {
      "name": "Launcher Picker Dry Run",
      "description": "Resolve a file/app/repo search into a launch plan without opening cmux or Codex app.",
      "keywords": ["launcher", "picker", "dry run", "github"],
      "command": "bin/cmux-codex-launcher --choose --query penny --dry-run"
    },
    {
      "name": "Launcher Dry Run",
      "description": "Print the Penny launcher plan without opening cmux or Codex app.",
      "keywords": ["launcher", "dry run", "penny"],
      "command": "bin/cmux-codex-launcher --profile penny --dry-run"
    },
    {
      "name": "Launcher Tests",
      "description": "Run shell checks for the launcher.",
      "keywords": ["test", "launcher"],
      "command": "bash scripts/test-launcher.sh"
    }
  ]
}
